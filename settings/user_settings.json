{
  "system_prompt": "Custom system prompt",
  "default_provider": "ollama",
  "default_model": "gemma3:4b",
  "temperature": 1.0,
  "max_tokens": 3000,
  "hands_free": {
    "wake_words": [
      "hey amber",
      "hi amber",
      "amber",
      "hey ember",
      "hi ember",
      "ember"
    ],
    "sleep_words": [
      "sleep amber",
      "goodbye amber",
      "stop amber",
      "sleep ember",
      "goodbye ember",
      "stop ember"
    ],
    "silence_timeout_seconds": 8
  }
}